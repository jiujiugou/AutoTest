{
  "steps": [
    {
      "name": "fetchBaidu",
      "type": "http",
      "input": {
        "url": "https://www.baidu.com",
        "method": "Get",
        "timeout": 10
      },
      "extract": [
        { "name": "statusCode", "source": "Header", "method": "Plain", "expression": "StatusCode" }
      ],
      "assertions": [
        { "field": "StatusCode", "operator": "Equal", "expected": "200" }
      ],
      "timeout": "15s"
    },
    {
      "name": "verifyExtractedCode",
      "type": "http",
      "input": {
        "url": "https://www.baidu.com",
        "method": "Get",
        "timeout": 10
      },
      "assertions": [
        { "field": "StatusCode", "operator": "Equal", "expected": "{{fetchBaidu.statusCode}}" }
      ],
      "timeout": "15s",
      "onFailure": "stop"
    }
  ]
}
